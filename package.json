{
  "name": "metacognitive-compute-scheduler-emms-messo139",
  "version": "0.1.0",
  "description": "An MCP service that decides how much compute each agent step deserves (System 1 vs System 2) and learns that judgment from experience. EMMS compromise-in-competition mapped onto the dual-process boundary.",
  "type": "module",
  "bin": {
    "conscious-scheduler": "server.mjs"
  },
  "main": "consciousCore.mjs",
  "scripts": {
    "start": "node server.mjs",
    "start:executor": "node -e \"process.env.EMMS_EXECUTOR_ENDPOINT='1';import('./server.mjs')\"",
    "smoke": "node smoke.mjs",
    "test:isolation": "node endpointIsolationTest.mjs",
    "complex": "node complexTask.mjs",
    "tests": "node answerTests.mjs",
    "skill-gate": "node skillGateTest.mjs",
    "eval": "node eval_swebpro_clusters.mjs --seeds 24 --sessions 60 --noise 0.3",
    "figdata": "node figures/gen_fig_data.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm-agent",
    "metacognition",
    "compute-routing",
    "dual-process",
    "system1-system2",
    "emms",
    "test-time-compute"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "LZF1111",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LZF1111/metacognitive-compute-scheduler-EMMS-messo139.git"
  },
  "dependencies": {}
}
